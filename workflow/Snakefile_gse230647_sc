#!/usr/bin/env snakemake -s
"""
Single-cell RNA-seq reanalysis of the TDP-43-HA overexpression experiment
in GSE230647 (SRA study SRP434658, BioProject PRJNA962064).

https://www.ncbi.nlm.nih.gov/geo/query/acc.cgi?acc=GSE230647

Four 10x Chromium 3' v3 samples: three TDP-43-HA DOX-on replicates and one
DOX-off control. Each sample spans two sequencing lanes (two SRR accessions).
Cells cluster into 17 types; cluster 12 marks TDP-43-HA-expressing cells.
Cell-type annotations per CB are provided in the GEO supplementary file
GSE230647_single_cell_metadata_tdp43ha.txt.gz.

STARsolo (CB_UMI_Simple) and kallisto|bustools quantify each sample against
gene and repeat (genic and intergenic) annotations, sharing reference indices
with the companion bulk pipeline (Snakefile_gse230647).

Run from the workflow/ directory with
    snakemake -s Snakefile_gse230647_sc \\
        --configfile configs/gse230647_sc.yaml \\
        --use-conda --cores 10
"""

import os
import os.path as op

configfile: "configs/gse230647_sc.yaml"

if "indices_base" not in config:
    config["indices_base"] = config["base"]

_chroms = config["reference"].get("chromosomes", [])
genome_tag = "_".join(sorted(_chroms)) if _chroms else "all"

_sc_samples = config["dataset"]["samples"]
_sample_ids = sorted(_sc_samples.keys())
_cb_len = config["real_data"].get("cb_length", 16)
_umi_len = config["real_data"].get("umi_length", 12)
_umi_start = _cb_len + 1

include: "modules/download_references.snmk"
include: "modules/reference.snmk"

for subdir in ["tmp", "logs", "benchmarks", "metadata"]:
    os.makedirs(op.join(config["base"], subdir), exist_ok=True)
for subdir in ["indices", "refs"]:
    os.makedirs(op.join(config["indices_base"], subdir), exist_ok=True)

active_aligners = config.get("aligners", [])
feature_sets = config.get("feature_sets", ["genic_repeats"])
starsolo_modes = (config.get("aligner_params", {}).get("starsolo", {})
                  .get("multimapper_modes", ["unique"]))

_repeat_fsets = [fs for fs in feature_sets
                 if fs in ("genic_repeats", "intergenic_repeats")]


def srrs_for(sample_id):
    return _sc_samples[sample_id]["srrs"]


def srr_r1(sample_id, srr):
    # read position 2: R1 (cell barcode + UMI), produced by fasterq-dump --include-technical
    return op.join(config["base"], "data", "raw", sample_id, f"{srr}_2.fastq.gz")


def srr_r2(sample_id, srr):
    # read position 3: R2 (cDNA), produced by fasterq-dump --include-technical
    return op.join(config["base"], "data", "raw", sample_id, f"{srr}_3.fastq.gz")


def sample_r1_files(sample_id):
    return [srr_r1(sample_id, srr) for srr in srrs_for(sample_id)]


def sample_r2_files(sample_id):
    return [srr_r2(sample_id, srr) for srr in srrs_for(sample_id)]


def reference_outputs():
    refs = op.join(config["indices_base"], "indices", genome_tag)
    return [
        op.join(refs, "genic_repeats.gtf"),
        op.join(refs, "intergenic_repeats.gtf"),
        op.join(refs, "repeat_harboring_genes.gtf"),
    ]


def starsolo_bams():
    if "starsolo" not in active_aligners:
        return []
    return [
        op.join(config["base"], "starsolo", sid,
                f"{mode}_{fs}", "Aligned.sortedByCoord.out.bam")
        for sid in _sample_ids
        for mode in starsolo_modes
        for fs in feature_sets
    ]


def kallisto_counts():
    if "kallisto" not in active_aligners:
        return []
    return [
        op.join(config["base"], "kallisto", fs, sid, "counts.mtx")
        for sid in _sample_ids
        for fs in feature_sets
    ]


_metadata_gz = op.join(config["base"], "metadata", "tdp43ha_cell_metadata.txt.gz")
_metadata_txt = op.join(config["base"], "metadata", "tdp43ha_cell_metadata.txt")
_report_html = op.join(config["base"], "gse230647_sc_report.html")
_report_outdir = op.join(config["base"], "report_rds")


rule all:
    default_target: True
    input:
        reference_outputs(),
        [srr_r1(sid, srr) for sid in _sample_ids for srr in srrs_for(sid)],
        [srr_r2(sid, srr) for sid in _sample_ids for srr in srrs_for(sid)],
        starsolo_bams(),
        kallisto_counts(),
        _metadata_txt,
        _report_html,


rule download_sra_gse230647_sc:
    conda:
        op.join(workflow.basedir, "envs", "sratools.yaml")
    output:
        r1 = op.join(config["base"], "data", "raw", "{sample_id}", "{srr}_2.fastq.gz"),
        r2 = op.join(config["base"], "data", "raw", "{sample_id}", "{srr}_3.fastq.gz"),
    params:
        outdir = op.join(config["base"], "data", "raw", "{sample_id}"),
    log:
        op.join(config["base"], "logs", "download_{sample_id}_{srr}.log"),
    threads: 4
    shell:
        """
        mkdir -p {params.outdir}
        rm -f {params.outdir}/{wildcards.srr}_*.fastq {params.outdir}/{wildcards.srr}_*.fastq.gz
        fasterq-dump {wildcards.srr} \
            --split-files \
            --include-technical \
            --threads {threads} \
            --outdir {params.outdir} \
            &> {log}
        rm -f {params.outdir}/{wildcards.srr}_1.fastq
        gzip {params.outdir}/{wildcards.srr}_2.fastq
        gzip {params.outdir}/{wildcards.srr}_3.fastq
        """


rule starsolo_chromium_sc:
    wildcard_constraints:
        multimapper_mode = "unique|multi",
        feature_set = "genes|genic_repeats|intergenic_repeats",
    conda:
        op.join(workflow.basedir, "envs", "star.yaml")
    input:
        index = rules.star_genome_index.output.index,
        gtf = gtf_for_feature_set,
        r1 = lambda wc: sample_r1_files(wc.sample_id),
        r2 = lambda wc: sample_r2_files(wc.sample_id),
    output:
        bam = op.join(config["base"], "starsolo", "{sample_id}",
                      "{multimapper_mode}_{feature_set}",
                      "Aligned.sortedByCoord.out.bam"),
        raw_dir = directory(op.join(config["base"], "starsolo", "{sample_id}",
                                    "{multimapper_mode}_{feature_set}",
                                    "Solo.out", "Gene", "raw")),
    params:
        out_prefix = op.join(config["base"], "starsolo", "{sample_id}",
                             "{multimapper_mode}_{feature_set}") + "/",
        index_dir = op.join(config["indices_base"], "indices", genome_tag, "star"),
        tmp_dir = op.join(config["base"], "tmp",
                          "starsolo_{sample_id}_{multimapper_mode}_{feature_set}"),
        solo_multimappers = lambda wc: {"unique": "Unique", "multi": "EM"}[wc.multimapper_mode],
        max_ram_bytes = config["resources"]["max_mem_mb"] * 1024 * 1024,
        cb_len = _cb_len,
        umi_len = _umi_len,
        umi_start = _umi_start,
        r2_csv = lambda wc, input: ",".join(input.r2),
        r1_csv = lambda wc, input: ",".join(input.r1),
        extra_args = config.get("aligner_params", {}).get("starsolo", {}).get("extra_args", ""),
    log:
        op.join(config["base"], "logs",
                "starsolo_{sample_id}_{multimapper_mode}_{feature_set}.log"),
    benchmark:
        op.join(config["base"], "benchmarks",
                "starsolo_{sample_id}_{multimapper_mode}_{feature_set}.txt"),
    threads: workflow.cores
    shell:
        """
        rm -rf {params.tmp_dir} {params.out_prefix}Solo.out
        mkdir -p {params.tmp_dir} {params.out_prefix}

        STAR --runThreadN {threads} \
             --runDirPerm All_RWX \
             --soloType CB_UMI_Simple \
             --genomeDir {params.index_dir} \
             --readFilesIn {params.r2_csv} {params.r1_csv} \
             --readFilesCommand pigz -d -c \
             --outFileNamePrefix {params.out_prefix} \
             --sjdbGTFfile {input.gtf} \
             --soloFeatures Gene \
             --soloCBwhitelist None \
             --soloCellFilter None \
             --soloCBstart 1 --soloCBlen {params.cb_len} \
             --soloUMIstart {params.umi_start} \
             --soloUMIlen {params.umi_len} \
             --soloMultiMappers {params.solo_multimappers} \
             --outSAMattributes NH HI AS NM CB UB \
             --outSAMtype BAM SortedByCoordinate \
             --limitBAMsortRAM {params.max_ram_bytes} \
             {params.extra_args} 2> {log}

        rm -rf {params.tmp_dir}
        """


rule kallisto_bus_sc:
    wildcard_constraints:
        feature_set = "genes|genic_repeats|intergenic_repeats",
    conda:
        op.join(workflow.basedir, "envs", "kallisto.yaml")
    input:
        index = lambda wc: op.join(config["indices_base"], "indices", genome_tag,
                                   "kallisto", f"{wc.feature_set}.idx"),
        r1 = lambda wc: sample_r1_files(wc.sample_id),
        r2 = lambda wc: sample_r2_files(wc.sample_id),
    output:
        bus = op.join(config["base"], "kallisto", "{feature_set}",
                      "{sample_id}", "output.bus"),
        ec = op.join(config["base"], "kallisto", "{feature_set}",
                     "{sample_id}", "matrix.ec"),
        transcripts = op.join(config["base"], "kallisto", "{feature_set}",
                              "{sample_id}", "transcripts.txt"),
    params:
        outdir = op.join(config["base"], "kallisto", "{feature_set}", "{sample_id}"),
        r1_r2_pairs = lambda wc, input: " ".join(
            f"{r1} {r2}" for r1, r2 in zip(input.r1, input.r2)
        ),
        extra_args = config.get("aligner_params", {}).get("kallisto", {}).get("extra_args", ""),
    log:
        op.join(config["base"], "logs",
                "kallisto_bus_{feature_set}_{sample_id}.log"),
    benchmark:
        op.join(config["base"], "benchmarks",
                "kallisto_bus_{feature_set}_{sample_id}.txt"),
    threads: workflow.cores
    shell:
        """
        kallisto bus \
            --index {input.index} \
            --output-dir {params.outdir} \
            -x 10xv3 \
            --threads {threads} \
            {params.extra_args} \
            {params.r1_r2_pairs} 2> {log}
        """


rule bustools_sort_sc:
    wildcard_constraints:
        feature_set = "genes|genic_repeats|intergenic_repeats",
    conda:
        op.join(workflow.basedir, "envs", "kallisto.yaml")
    input:
        op.join(config["base"], "kallisto", "{feature_set}", "{sample_id}", "output.bus"),
    output:
        op.join(config["base"], "kallisto", "{feature_set}", "{sample_id}", "output.sorted.bus"),
    log:
        op.join(config["base"], "logs",
                "bustools_sort_{feature_set}_{sample_id}.log"),
    benchmark:
        op.join(config["base"], "benchmarks",
                "bustools_sort_{feature_set}_{sample_id}.txt"),
    threads: workflow.cores
    shell:
        """
        bustools sort \
            --threads {threads} \
            -o {output} \
            {input} 2> {log}
        """


rule bustools_count_sc:
    wildcard_constraints:
        feature_set = "genes|genic_repeats|intergenic_repeats",
    conda:
        op.join(workflow.basedir, "envs", "kallisto.yaml")
    input:
        bus = op.join(config["base"], "kallisto", "{feature_set}",
                      "{sample_id}", "output.sorted.bus"),
        ec = op.join(config["base"], "kallisto", "{feature_set}",
                     "{sample_id}", "matrix.ec"),
        transcripts = op.join(config["base"], "kallisto", "{feature_set}",
                              "{sample_id}", "transcripts.txt"),
        t2g = lambda wc: t2g_path(wc),
    output:
        counts = op.join(config["base"], "kallisto", "{feature_set}",
                         "{sample_id}", "counts.mtx"),
        barcodes = op.join(config["base"], "kallisto", "{feature_set}",
                           "{sample_id}", "counts.barcodes.txt"),
        genes = op.join(config["base"], "kallisto", "{feature_set}",
                        "{sample_id}", "counts.genes.txt"),
    params:
        out_prefix = op.join(config["base"], "kallisto", "{feature_set}",
                             "{sample_id}", "counts"),
    log:
        op.join(config["base"], "logs",
                "bustools_count_{feature_set}_{sample_id}.log"),
    benchmark:
        op.join(config["base"], "benchmarks",
                "bustools_count_{feature_set}_{sample_id}.txt"),
    shell:
        """
        bustools count \
            --ec {input.ec} \
            --txnames {input.transcripts} \
            --genemap {input.t2g} \
            --genecounts \
            --output {params.out_prefix} \
            {input.bus} 2> {log}
        """


rule download_geo_metadata_sc:
    output:
        gz = _metadata_gz,
        txt = _metadata_txt,
    params:
        url = config["dataset"]["metadata_url"],
    log:
        op.join(config["base"], "logs", "download_geo_metadata.log"),
    shell:
        """
        curl -fsSL '{params.url}' -o {output.gz} 2> {log}
        gunzip -c {output.gz} > {output.txt}
        """


rule render_report_gse230647_sc:
    conda:
        op.join(workflow.basedir, "envs", "edger.yaml")
    input:
        starsolo_bams = starsolo_bams(),
        kallisto_counts = kallisto_counts(),
        metadata = _metadata_txt,
        sample_metadata = op.join(workflow.basedir,
                                  config["dataset"]["sample_metadata"]),
        rmd = op.join(workflow.basedir, "scripts", "gse230647_sc_report.Rmd"),
    output:
        html = _report_html,
    params:
        starsolo_base = op.abspath(op.join(config["base"], "starsolo")),
        kallisto_base = op.abspath(op.join(config["base"], "kallisto")),
        indices_base = op.abspath(op.join(config["indices_base"], "indices", genome_tag)),
        metadata = op.abspath(_metadata_txt),
        sample_metadata = op.abspath(op.join(workflow.basedir,
                                             config["dataset"]["sample_metadata"])),
        report_outdir = op.abspath(_report_outdir),
        abs_html = op.abspath(_report_html),
        rmd = op.join(workflow.basedir, "scripts", "gse230647_sc_report.Rmd"),
        feature_sets = " ".join(feature_sets),
        starsolo_modes = " ".join(starsolo_modes),
    log:
        op.join(config["base"], "logs", "gse230647_sc_render_report.log"),
    shell:
        """
        mkdir -p {params.report_outdir}
        Rscript -e "rmarkdown::render(
            '{params.rmd}',
            output_file = '{params.abs_html}',
            knit_root_dir = getwd(),
            params = list(
                starsolo_base  = '{params.starsolo_base}',
                kallisto_base  = '{params.kallisto_base}',
                indices_base   = '{params.indices_base}',
                metadata       = '{params.metadata}',
                sample_metadata = '{params.sample_metadata}',
                report_outdir  = '{params.report_outdir}',
                feature_sets   = '{params.feature_sets}',
                starsolo_modes = '{params.starsolo_modes}'
            )
        )" 2> {log}
        """
