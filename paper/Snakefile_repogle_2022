#!/usr/bin/env snakemake -s
"""
repogle_2022 use case (Replogle et al. 2022 K562 essential Perturb-seq).

Three phases:

Phase 1 - figshare metadata download and cell selection.
  Rules: download_repogle_2022_figshare, select_repogle_2022_cells.
  Output: selected_perturbations.tsv, cells_to_perturbation.tsv,
          selected_libraries.tsv.

Phase 2 prep - SRA accession resolution per library.
  Rule: resolve_repogle_2022_sra.
  Outputs:
    selected_libraries_with_srrs.tsv  augmented manifest with SRR ids
    repogle_kd6_sc_merged.yaml        complete workflow config with samples
                                       merged in, used as the single
                                       --configfile for Phase 2 alignment

The actual alignment (Phase 2) is invoked separately on the compute machine:

  cd workflow
  snakemake --use-conda --cores N \\
      --configfile ../results/paper/repogle_2022/data/repogle_kd6_sc_merged.yaml


Phase 3 - per-perturbation pseudobulk RUVg DE plus per-library alignment QC.
  Rules: aggregate_star_alignment_qc, render_repogle_2022_perturbseq_report.
  The first scans STAR Log.final.out files emitted by Phase 2 and emits a
  per-library QC TSV. The second consumes STARsolo matrices, the QC TSV,
  the locus_map files for family/class rollups, and cells_to_perturbation
  to render the paper-figure HTML plus CSV/RDS outputs under
  <out_base>/report/.

Run Phase 1 + Phase 2 prep:
  cd paper
  snakemake -s Snakefile_repogle_2022 --use-conda --cores 2 \\
      --configfile configs/repogle_2022.yaml

Run Phase 3 after the workflow alignment completes:
  snakemake -s Snakefile_repogle_2022 --use-conda --cores 4 \\
      --configfile configs/repogle_2022.yaml \\
      ../results/paper/repogle_2022/report/ruv_repogle_2022_perturbseq_report.html
"""

import os.path as op
import re

configfile: "configs/repogle_2022.yaml"

_out = config['out_base']
_dl = op.join(_out, "figshare")
_data = op.join(_out, "data")
_report = op.join(_out, "report")

_files = config['files']
_file_names = [f['name'] for f in _files.values()]
_file_name_re = "|".join(re.escape(n) for n in _file_names)


def _file_attr(name, key):
    for f in _files.values():
        if f['name'] == name:
            return f[key]
    raise KeyError(f"unknown file {name}")


rule all:
    default_target: True
    input:
        op.join(_data, "selected_perturbations.tsv"),
        op.join(_data, "cells_to_perturbation.tsv"),
        op.join(_data, "selected_libraries.tsv"),
        op.join(_data, "selected_libraries_with_srrs.tsv"),
        op.join(_data, "repogle_kd6_sc_merged.yaml"),


rule download_repogle_2022_figshare:
    output:
        op.join(_dl, "{name}")
    wildcard_constraints:
        name = _file_name_re
    params:
        url = lambda wc: _file_attr(wc.name, "url"),
        md5 = lambda wc: _file_attr(wc.name, "md5"),
        size = lambda wc: _file_attr(wc.name, "size"),
        outdir = _dl,
    log:
        op.join(_out, "logs", "download_{name}.log"),
    resources:
        mem_mb = config.get("resources", {}).get("download_mem_mb", 1000),
    shell:
        """
        mkdir -p {params.outdir} $(dirname {log})
        wget --tries=3 --continue --progress=dot:giga \\
            -O {output} {params.url} 2> {log}
        actual_size=$(stat -c%s {output})
        if [ "$actual_size" != "{params.size}" ]; then
            echo "size mismatch for {wildcards.name}: got $actual_size expected {params.size}" >> {log}
            exit 1
        fi
        actual_md5=$(md5sum {output} | awk '{{print $1}}')
        if [ "$actual_md5" != "{params.md5}" ]; then
            echo "md5 mismatch for {wildcards.name}: got $actual_md5 expected {params.md5}" >> {log}
            exit 1
        fi
        echo "ok $actual_md5  {output}" >> {log}
        """


rule select_repogle_2022_cells:
    conda:
        "envs/repogle_metadata.yaml"
    input:
        manifest = op.join(_dl, _files['manifest_kd6']['name']),
        bulk = op.join(_dl, _files['bulk_h5ad']['name']),
        singlecell = op.join(_dl, _files['singlecell_h5ad']['name']),
        script = op.join(workflow.basedir, "scripts",
                         "select_repogle_2022_cells.py"),
    output:
        perturbations = op.join(_data, "selected_perturbations.tsv"),
        cells = op.join(_data, "cells_to_perturbation.tsv"),
        libraries = op.join(_data, "selected_libraries.tsv"),
    params:
        outdir = _data,
        top_n = config['selection']['top_n_perturbations'],
        n_controls = config['selection']['n_controls'],
        min_cells = config['selection']['min_cells_per_perturbation'],
        seed = config['selection']['seed'],
        gemgroups = ",".join(str(g) for g in config.get('gemgroup_subset', [])),
    log:
        op.join(_out, "logs", "select_cells.log"),
    resources:
        mem_mb = config.get("resources", {}).get("select_mem_mb", 8000),
    shell:
        """
        mkdir -p {params.outdir} $(dirname {log})
        python {input.script} \\
            --bulk {input.bulk} \\
            --singlecell {input.singlecell} \\
            --manifest {input.manifest} \\
            --top-n {params.top_n} \\
            --n-controls {params.n_controls} \\
            --min-cells {params.min_cells} \\
            --seed {params.seed} \\
            --gemgroups "{params.gemgroups}" \\
            --out-perturbations {output.perturbations} \\
            --out-cells {output.cells} \\
            --out-libraries {output.libraries} \\
            2> {log}
        """


rule resolve_repogle_2022_sra:
    conda:
        "envs/repogle_metadata.yaml"
    input:
        libraries = op.join(_data, "selected_libraries.tsv"),
        script = op.join(workflow.basedir, "scripts",
                         "resolve_repogle_2022_sra.py"),
        workflow_config = op.join(workflow.basedir, "..", "workflow",
                                   "configs", "repogle_kd6_sc.yaml"),
    output:
        tsv = op.join(_data, "selected_libraries_with_srrs.tsv"),
        merged_yaml = op.join(_data, "repogle_kd6_sc_merged.yaml"),
    params:
        outdir = _data,
        bioproject = config['sra']['bioproject'],
        kd_label = config['sra']['kd_label'],
        source_pattern = config['sra']['source_pattern'],
    log:
        op.join(_out, "logs", "resolve_sra.log"),
    resources:
        mem_mb = config.get("resources", {}).get("resolve_sra_mem_mb", 4000),
    shell:
        """
        mkdir -p {params.outdir} $(dirname {log})
        python {input.script} \\
            --bioproject {params.bioproject} \\
            --kd-label {params.kd_label} \\
            --source-pattern {params.source_pattern} \\
            --libraries {input.libraries} \\
            --out-tsv {output.tsv} \\
            --workflow-config {input.workflow_config} \\
            --out-merged-yaml {output.merged_yaml} \\
            2> {log}
        """


# Per-library STAR alignment QC. Reads one Log.final.out per library
# (unique_genes is canonical; the alignment is identical across modes and
# feature_sets so the unique_genes log captures mismatch rate, mapping
# rates, and read counts for the library). Discovery is by glob so the
# rule does not need to enumerate the 48 KD6 libraries explicitly.
rule aggregate_star_alignment_qc:
    conda:
        "envs/repogle_metadata.yaml"
    input:
        libraries = op.join(_data, "selected_libraries_with_srrs.tsv"),
        script = op.join(workflow.basedir, "..", "workflow", "scripts",
                         "parse_star_log.py"),
    output:
        tsv = op.join(_report, "alignment_qc_per_library.tsv"),
    params:
        outdir = _report,
        starsolo_base = op.abspath(config['phase3']['starsolo_base']),
    log:
        op.join(_out, "logs", "alignment_qc_per_library.log"),
    resources:
        mem_mb = 1000,
    shell:
        """
        mkdir -p {params.outdir} $(dirname {log})
        shopt -s nullglob
        logs=({params.starsolo_base}/*/unique_genes/Log.final.out)
        if [ ${{#logs[@]}} -eq 0 ]; then
            echo "no STAR Log.final.out found under {params.starsolo_base}" >&2
            exit 1
        fi
        args=()
        for f in "${{logs[@]}}"; do args+=(--log "$f"); done
        python {input.script} "${{args[@]}}" --out {output.tsv} 2> {log}
        """


rule render_repogle_2022_perturbseq_report:
    conda:
        "envs/ruvseq.yaml"
    input:
        rmd = op.join(workflow.basedir, "scripts",
                      "ruv_repogle_2022_perturbseq_report.Rmd"),
        cells = op.join(_data, "cells_to_perturbation.tsv"),
        perturbations = op.join(_data, "selected_perturbations.tsv"),
        alignment_qc = op.join(_report, "alignment_qc_per_library.tsv"),
    output:
        html = op.join(_report, "ruv_repogle_2022_perturbseq_report.html"),
        rds_dir = directory(op.join(_report, "ruv_rds")),
    params:
        rmd = op.abspath(op.join(workflow.basedir, "scripts",
                                 "ruv_repogle_2022_perturbseq_report.Rmd")),
        abs_html = op.abspath(op.join(_report,
                                      "ruv_repogle_2022_perturbseq_report.html")),
        outdir = op.abspath(op.join(_report, "ruv_rds")),
        cells = op.abspath(op.join(_data, "cells_to_perturbation.tsv")),
        perturbations = op.abspath(op.join(_data, "selected_perturbations.tsv")),
        alignment_qc = op.abspath(op.join(_report, "alignment_qc_per_library.tsv")),
        starsolo_base = op.abspath(config['phase3']['starsolo_base']),
        starsolo_tagcount_base = (
            op.abspath(config['phase3']['starsolo_tagcount_base'])
            if 'starsolo_tagcount_base' in config.get('phase3', {}) else ""),
        indices_base = op.abspath(config['phase3']['indices_base']),
        feature_sets = config['phase3']['feature_sets'],
        starsolo_modes = config['phase3']['starsolo_modes'],
        n_controls = int(config['phase3']['n_controls']),
        k_selected = int(config['phase3']['k_selected']),
        min_cells_per_col = int(config['phase3']['min_cells_per_perturbation_col']),
    log:
        op.join(_out, "logs", "render_perturbseq_report.log"),
    resources:
        mem_mb = config.get("resources", {}).get("ruv_mem_mb", 32000),
    shell:
        """
        mkdir -p {params.outdir} $(dirname {log})
        Rscript -e "rmarkdown::render(
            '{params.rmd}',
            output_file = '{params.abs_html}',
            knit_root_dir = getwd(),
            params = list(
                cells_to_perturbation = '{params.cells}',
                selected_perturbations = '{params.perturbations}',
                alignment_qc = '{params.alignment_qc}',
                starsolo_base = '{params.starsolo_base}',
                starsolo_tagcount_base = '{params.starsolo_tagcount_base}',
                indices_base = '{params.indices_base}',
                report_outdir = '{params.outdir}',
                feature_sets = '{params.feature_sets}',
                starsolo_modes = '{params.starsolo_modes}',
                n_controls = {params.n_controls},
                k_selected = {params.k_selected},
                min_cells_per_col = {params.min_cells_per_col}
            )
        )" 2> {log}
        """
